# AgriSmartAI environment variables (Capstone Final)
# Copy to .env in project root

# PostgreSQL (Python backend connects here)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agrismartai

# Backend API URL (Flutter apps call this — NOT PostgreSQL directly)
API_BASE_URL=http://localhost:8000
PORT=8000

# Defense mode: simulated MobileNetV2 (1=on, 0=real heuristics)
DEFENSE_MODE=1
